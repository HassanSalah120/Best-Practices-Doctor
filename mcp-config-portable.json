{
  "mcpServers": {
    "bpdoctor": {
      "command": "npm",
      "args": ["--prefix", "./bpdoctor-mcp", "run", "dev"],
      "disabled": false,
      "env": {
        "BPDOCTOR_API_BASE_URL": "http://127.0.0.1:50401",
        "BPDOCTOR_API_TOKEN": "SET_FROM_RUNTIME_DISCOVERY",
        "BPDOCTOR_WORKSPACE_ROOT": "."
      }
    }
  }
}
