{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "python-backend",
          "cmd": "python-backend",
          "args": true
        }
      ]
    },
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-message",
    "fs:allow-read"
  ]
}
